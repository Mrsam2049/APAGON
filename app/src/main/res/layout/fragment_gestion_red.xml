<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_frame"
    android:orientation="vertical">

    <!-- Cabecera -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/headerIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Noche tranquila"
                android:textColor="@color/text_strong"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/headerSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apartadó · Noche 1"
                android:textColor="@color/text_dim"
                android:textSize="8sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tagBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:background="@drawable/pill"
            android:backgroundTint="#1560A5FA"
            android:paddingHorizontal="9dp"
            android:paddingVertical="4dp"
            android:text="💰 $28M"
            android:textColor="@color/blue_light"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tagPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pill"
            android:backgroundTint="#15F97316"
            android:paddingHorizontal="9dp"
            android:paddingVertical="4dp"
            android:text="⚡ 2"
            android:textColor="@color/orange"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Indicadores -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="2dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp">

        <com.iue.apagon.ui.widget.GaugeView
            android:id="@+id/gaugeCob"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="7dp"
            android:layout_weight="1" />

        <com.iue.apagon.ui.widget.GaugeView
            android:id="@+id/gaugePre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="7dp"
            android:layout_weight="1" />

        <com.iue.apagon.ui.widget.GaugeView
            android:id="@+id/gaugeSoc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="7dp"
            android:layout_weight="1" />

        <com.iue.apagon.ui.widget.GaugeView
            android:id="@+id/gaugeAmb"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Carga / disponible -->
    <LinearLayout
        android:id="@+id/energyPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="14dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_inset"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/carga_disponible"
                android:textColor="@color/text_muted"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/energyValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 72 MW"
                android:textColor="@color/green"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/energyBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            app:indicatorColor="@color/green"
            app:trackColor="@color/bg_inset_2"
            app:trackCornerRadius="4dp"
            app:trackThickness="7dp"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <TextView
            android:id="@+id/energyNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/sobrecarga_aviso"
            android:textColor="@color/red"
            android:textSize="8sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginBottom="5dp"
        android:letterSpacing="0.1"
        android:text="@string/distritos_hint"
        android:textColor="@color/text_dim"
        android:textSize="8sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/districtGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="14dp"
        android:nestedScrollingEnabled="false"
        android:overScrollMode="never"
        tools:listitem="@layout/item_district" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="6dp" />

    <!-- Mano -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/handLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:letterSpacing="0.1"
            android:text="🃏 MANO · 2 jugadas"
            android:textColor="@color/text_dim"
            android:textSize="8sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/campaignBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/pill"
            android:backgroundTint="#1522C55E"
            android:paddingHorizontal="7dp"
            android:paddingVertical="2dp"
            android:text="📢 Campaña activa"
            android:textColor="@color/green"
            android:textSize="7sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/handList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="4dp"
        tools:listitem="@layout/item_card" />

    <TextView
        android:id="@+id/btnEndNight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="14dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/btn_primary"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingVertical="14dp"
        android:text="@string/terminar_noche"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
