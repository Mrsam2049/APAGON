<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_root"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="34dp">

    <TextView
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:gravity="center"
        android:letterSpacing="0.2"
        android:text="APARTADÓ · NOCHE 1/5"
        android:textColor="@color/text_dim"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/scenarioIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:text="🌙"
        android:textSize="70sp" />

    <TextView
        android:id="@+id/scenarioTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:gravity="center"
        android:text="Noche tranquila"
        android:textColor="@color/blue"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/scenarioText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6"
        android:maxWidth="280dp"
        android:text="Primera noche de racionamiento. Demanda normal, pero los embalses ya bajan."
        android:textColor="@color/text"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="34dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/statEnergy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="72"
                android:textColor="@color/orange"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mw_disponibles"
                android:textColor="@color/text_dim"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/statBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$28M"
                android:textColor="@color/blue_light"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/presupuesto"
                android:textColor="@color/text_dim"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/btnGestionar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_primary"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="44dp"
        android:paddingVertical="15dp"
        android:text="@string/gestionar_red"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
