<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/resumenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_root"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="720dp"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:id="@+id/medalEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="🥇"
            android:textSize="64sp" />

        <TextView
            android:id="@+id/medalTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Final Oro"
            android:textColor="@color/amber"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/medalSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Transición Energética · Apartadó"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@drawable/rounded_16"
            android:backgroundTint="#14F59E0B"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/scoreValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7800"
                android:textColor="@color/amber"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/scoreLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:text="PUNTAJE — sobreviviste 5 noches"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnAgain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/btn_primary"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="26dp"
                android:paddingVertical="13dp"
                android:text="Otra vez"
                android:textColor="#060912"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_outline"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="26dp"
                android:paddingVertical="13dp"
                android:text="Menú"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
