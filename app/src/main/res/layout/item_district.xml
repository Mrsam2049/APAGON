<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/districtRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/district_on"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingVertical="9dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/statusEmoji"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💡"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ON"
            android:textColor="@color/green"
            android:textSize="8sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/districtIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏥"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/districtName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_weight="1"
            android:maxLines="1"
            android:text="Centro"
            android:textColor="@color/text_strong"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/districtRule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="2dp"
        android:lineSpacingMultiplier="1.2"
        android:text="No apagar 2 noches seguidas"
        android:textColor="@color/text_dim"
        android:textSize="7sp" />

    <TextView
        android:id="@+id/districtDemand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="26 MW"
        android:textColor="@color/blue_light"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>
