<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ApaGon" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/orange</item>
        <item name="colorOnPrimary">@color/text_strong</item>
        <item name="colorSecondary">@color/blue</item>
        <item name="android:colorBackground">@color/bg_root</item>
        <item name="android:windowBackground">@color/bg_root</item>
        <item name="android:statusBarColor">@color/bg_frame</item>
        <item name="android:navigationBarColor">@color/bg_frame</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Texto -->
    <style name="Text.Title" parent="">
        <item name="android:textColor">@color/text_strong</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Text.Body" parent="">
        <item name="android:textColor">@color/text</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="Text.Label" parent="">
        <item name="android:textColor">@color/text_dim</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
